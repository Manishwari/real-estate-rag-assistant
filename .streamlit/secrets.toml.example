# Copy this file to .streamlit/secrets.toml for local runs,
# or paste its contents into the "Secrets" box when deploying on
# Streamlit Community Cloud (Settings -> Secrets).

# Which LLM backend to use for answer generation: "groq" | "openai" | "anthropic"
GENERATOR_BACKEND = "groq"

# Get a free key at https://console.groq.com
GROQ_API_KEY = "your-groq-api-key-here"

# Only needed if GENERATOR_BACKEND = "openai"
# OPENAI_API_KEY = "your-openai-api-key-here"

# Only needed if GENERATOR_BACKEND = "anthropic"
# ANTHROPIC_API_KEY = "your-anthropic-api-key-here"

# Login credentials for the dashboard (username = password)
[auth]
users = { demo = "demo1234" }
